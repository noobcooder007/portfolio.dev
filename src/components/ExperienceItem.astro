---
interface Props {
  title: string;
  description: string;
  date: string;
}
const { title, description, date } = Astro.props;
---

<div
  class='absolute w-3 h-3 bg-mint-600 dark:bg-mint-300 rounded-full mt-1.5 -start-1.5 border border-mint-900/60 dark:border-mint-50/80 shadow-[0_0_8px_theme(colors.mint.400)]'
>
</div>
<time
  class='mb-1 text-md font-normal leading-none text-mint-600/80 dark:text-mint-300/80'
  >{date}</time
>
<h3 class='text-lg font-semibold text-mint-700 dark:text-mint-200 mt-2'>
  {title}
</h3>
<p class='mb-4 text-base font-normal text-mint-900/60 dark:text-mint-50/60 text-pretty'>
  {description}
</p>
